{
  "name": "interns-first-monorepo",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "backend",
    "frontend",
    "chatgroup"
  ],
  "scripts": {
    "backend:build": "npm run build --workspace=backend",
    "backend:start": "npm start --workspace=backend",
    "frontend:build": "npm run build --workspace=frontend",
    "frontend:start": "npm start --workspace=frontend",
    "chatgroup:build": "npm run build --workspace=chatgroup",
    "chatgroup:start": "npm start --workspace=chatgroup"
  }
}
